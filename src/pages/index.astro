<!-- CTA -->
<section class="slide slide--dark" id="cta">
  <div class="slide__inner fade-up cta">
    <p class="label" style="margin-bottom:2rem">Следующий шаг</p>
    <h2>Давайте раскроем потенциал вашего онлайна</h2>
    <p class="subhead">Предлагаю провести детальный аудит digital-каналов и&nbsp;подготовить конкретную дорожную карту развития.</p>
    <a href="https://t.me/ivkadatsky" class="cta-btn" target="_blank" rel="noopener">TG: @ivkadatsky</a>
    <p style="margin-top:1.5rem;font-size:.85rem;color:var(--text-muted)">Илья Кадацкий · E&#8209;commerce стратег</p>
  </div>
</section>
</div>

<script>
(function(){
  const wrapper = document.getElementById('slidesWrapper');
  const slides = wrapper.querySelectorAll('.hero, .slide');
  const total = slides.length;
  let current = 0;
  let isAnimating = false;
  const DURATION = 700;

  function goTo(idx) {
    if (idx < 0 || idx >= total || idx === current || isAnimating) return;
    isAnimating = true;
    current = idx;
    wrapper.style.transform = 'translateY(-' + (current * 100) + 'vh)';
    // trigger fade-up on current slide
    const inner = slides[current].querySelector('.fade-up');
    if (inner) inner.classList.add('visible');
    setTimeout(() => { isAnimating = false; }, DURATION);
  }

  // Show first slide
  const first = slides[0].querySelector('.fade-up');
  if (first) first.classList.add('visible');

  const isMobile = () => window.innerWidth <= 900;

  // Check if current slide content is scrolled to boundary
  function canLeave(dir) {
    if (!isMobile()) return true;
    const s = slides[current];
    const tol = 2;
    if (dir > 0) return s.scrollHeight - s.scrollTop - s.clientHeight <= tol;
    if (dir < 0) return s.scrollTop <= tol;
    return true;
  }

  // Track carousel card indices
  const carouselIdx = new Map();
  document.querySelectorAll('.carousel').forEach(c => {
    carouselIdx.set(c, 0);
  });

  function getCarouselTotal(carousel) {
    return carousel.querySelectorAll('.carousel__item').length;
  }

  function scrollCarouselTo(carousel, idx) {
    const items = carousel.querySelectorAll('.carousel__item');
    if (!items[idx]) return;
    carousel.style.scrollSnapType = 'none';
    carousel.style.scrollBehavior = 'smooth';
    const item = items[idx];
    const left = item.offsetLeft - carousel.offsetLeft - (carousel.clientWidth - item.offsetWidth) / 2;
    carousel.scrollTo({ left: Math.max(0, left), behavior: 'smooth' });
    setTimeout(() => { carousel.style.scrollSnapType = 'x mandatory'; }, 600);
  }

  // Mouse wheel
  let wheelAccum = 0;
  const WHEEL_THRESHOLD = 60;
  let wheelLocked = false;
  document.addEventListener('wheel', (e) => {
    const dir = e.deltaY > 0 ? 1 : -1;
    if (!canLeave(dir)) return;

    const carousel = !isMobile() && slides[current].querySelector('.carousel');
    if (carousel) {
      e.preventDefault();
      if (wheelLocked) return;
      wheelAccum += e.deltaY;
      if (Math.abs(wheelAccum) >= WHEEL_THRESHOLD) {
        const scrollDir = wheelAccum > 0 ? 1 : -1;
        const idx = carouselIdx.get(carousel) || 0;
        const tot = getCarouselTotal(carousel);
        const nextIdx = idx + scrollDir;
        wheelAccum = 0;

        if (nextIdx < 0) {
          goTo(current - 1);
        } else if (nextIdx >= tot) {
          goTo(current + 1);
        } else {
          wheelLocked = true;
          carouselIdx.set(carousel, nextIdx);
          scrollCarouselTo(carousel, nextIdx);
          setTimeout(() => { wheelLocked = false; }, 700);
        }
      }
      return;
    }

    e.preventDefault();
    wheelAccum += e.deltaY;
    if (Math.abs(wheelAccum) >= WHEEL_THRESHOLD) {
      goTo(current + (wheelAccum > 0 ? 1 : -1));
      wheelAccum = 0;
    }
  }, { passive: false });

  // Keyboard
  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowDown' || e.key === 'PageDown' || e.key === ' ') { e.preventDefault(); if (canLeave(1)) goTo(current + 1); }
    if (e.key === 'ArrowUp' || e.key === 'PageUp') { e.preventDefault(); if (canLeave(-1)) goTo(current - 1); }
    if (e.key === 'Home') { e.preventDefault(); goTo(0); }
    if (e.key === 'End') { e.preventDefault(); goTo(total - 1); }
  });

  // Touch swipe — on mobile check scroll boundary
  let touchY = 0;
  document.addEventListener('touchstart', (e) => {
    if (e.target.closest('.carousel')) return;
    touchY = e.touches[0].clientY;
  }, { passive: true });
  document.addEventListener('touchend', (e) => {
    if (e.target.closest('.carousel')) return;
    const diff = touchY - e.changedTouches[0].clientY;
    const dir = diff > 0 ? 1 : -1;
    if (Math.abs(diff) > 50 && canLeave(dir)) goTo(current + dir);
  }, { passive: true });

  // Carousel buttons
  document.querySelectorAll('.carousel__btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.dataset.carousel;
      const dir = parseInt(btn.dataset.dir);
      const carousel = document.getElementById(id);
      const item = carousel.querySelector('.carousel__item');
      const w = item.offsetWidth + 24;
      carousel.scrollBy({ left: dir * w, behavior: 'smooth' });
    });
  });

  // Carousel counters
  [['uxCarousel','uxCounter',6],['growthCarousel','growthCounter',7]].forEach(([cId,countId,tot]) => {
    const c = document.getElementById(cId);
    const counter = document.getElementById(countId);
    if (!c || !counter) return;
    c.addEventListener('scroll', () => {
      const item = c.querySelector('.carousel__item');
      const w = item.offsetWidth + 24;
      const idx = Math.round(c.scrollLeft / w) + 1;
      counter.textContent = idx + ' / ' + tot;
    });
  });

  // Drag scroll for carousels
  document.querySelectorAll('.carousel').forEach((c) => {
    let isDown = false, startX, scrollL, velX = 0, lastX, lastT, moved = false;
    // Prevent native image drag
    c.querySelectorAll('img').forEach(img => img.addEventListener('dragstart', e => e.preventDefault()));
    c.addEventListener('mousedown', (e) => {
      isDown = true; moved = false;
      startX = e.pageX; lastX = e.pageX; lastT = Date.now();
      scrollL = c.scrollLeft; velX = 0;
      c.style.scrollSnapType = 'none';
      c.style.scrollBehavior = 'auto';
    });
    const stop = () => {
      if (!isDown) return;
      isDown = false;
      c.style.scrollBehavior = 'smooth';
      c.style.scrollSnapType = 'x mandatory';
      // Snap to nearest card
      const item = c.querySelector('.carousel__item');
      if (item) {
        const w = item.offsetWidth + 32;
        const target = Math.round(c.scrollLeft / w) * w;
        c.scrollTo({ left: target, behavior: 'smooth' });
      }
    };
    c.addEventListener('mouseleave', stop);
    c.addEventListener('mouseup', stop);
    c.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX;
      const dx = x - lastX;
      if (Math.abs(x - startX) > 5) moved = true;
      c.scrollLeft = scrollL - (x - startX);
      lastX = x; lastT = Date.now();
    });
    // Prevent click on links/buttons after drag
    c.addEventListener('click', (e) => { if (moved) { e.preventDefault(); e.stopPropagation(); moved = false; } }, true);
  });

  // Vertical pagination
  const nav = document.createElement('nav');
  nav.className = 'slide-nav';
  nav.setAttribute('aria-label', 'Slide navigation');
  slides.forEach((s, i) => {
    const dot = document.createElement('button');
    dot.className = 'slide-nav__dot' + (i === 0 ? ' active' : '');
    dot.setAttribute('aria-label', 'Slide ' + (i + 1));
    dot.addEventListener('click', () => goTo(i));
    nav.appendChild(dot);
  });
  document.body.appendChild(nav);

  // Update pagination on slide change
  const origGoTo = goTo;
  function updateDots() {
    nav.querySelectorAll('.slide-nav__dot').forEach((d, i) => {
      d.classList.toggle('active', i === current);
    });
  }
  // Patch goTo to also update dots
  const _goTo = goTo;
  // We need to override — redefine goTo
  // Actually let's just use MutationObserver on wrapper transform
  const wrapperObs = new MutationObserver(() => updateDots());
  wrapperObs.observe(wrapper, { attributes: true, attributeFilter: ['style'] });
})();
</script>

